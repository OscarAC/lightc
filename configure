#!/bin/sh
# lightc — configure script
# Generates build.ninja for the selected build mode.
#
# Usage:
#   ./configure              — release (default)
#   ./configure debug        — debug symbols, no optimization
#   ./configure tiny         — minimal binary size, stripped
#   ./configure clean        — remove build artifacts

set -e

ARCH=$(uname -m)
CC=${CC:-gcc}
AR=${AR:-ar}
BUILDDIR="build"

# --- Detect C23 flag (GCC 14+ uses -std=c23, older uses -std=c2x) ---

if $CC -std=c23 -x c -E /dev/null >/dev/null 2>&1; then
    CSTD="-std=c23"
else
    CSTD="-std=c2x"
fi

# --- Build mode ---

MODE="${1:-release}"

case "$MODE" in
    debug)
        CFLAGS="$CSTD -O0 -g3 -Wall -Wextra -Wpedantic"
        LDFLAGS="-static -no-pie"
        LDSCRIPT="lightc.ld"
        STRIP=""
        DESC="debug (no optimization, full debug symbols)"
        ;;
    release)
        CFLAGS="$CSTD -O2 -DNDEBUG -Wall -Wextra -Wpedantic"
        LDFLAGS="-static -no-pie"
        LDSCRIPT="lightc.ld"
        STRIP="strip \$out"
        DESC="release (optimized, stripped)"
        ;;
    tiny)
        CFLAGS="$CSTD -Os -DNDEBUG -Wall -Wextra -Wpedantic -fno-asynchronous-unwind-tables"
        LDFLAGS="-static -no-pie"
        LDSCRIPT="lightc-tiny.ld"
        STRIP="strip \$out && objcopy --strip-section-headers \$out"
        DESC="tiny (minimal binary size)"
        ;;
    clean)
        echo "Cleaning ${BUILDDIR}/"
        rm -rf "$BUILDDIR"
        exit 0
        ;;
    *)
        echo "Unknown mode: $MODE"
        echo "Usage: $0 [debug|release|tiny|clean]"
        exit 1
        ;;
esac

# --- Map uname -m to our arch dirs ---

case "$ARCH" in
    x86_64)  ARCH_DIR="x86_64"  ;;
    aarch64) ARCH_DIR="aarch64" ;;
    *)
        echo "Unsupported architecture: $ARCH"
        exit 1
        ;;
esac

COMMON_FLAGS="-ffreestanding -nostdlib -nostartfiles -nodefaultlibs -fno-stack-protector -Iinclude"

# --- Generate build.ninja ---

cat > build.ninja << EOF
# lightc — generated by ./configure
# Mode: ${DESC}
# Arch: ${ARCH_DIR}
#
# Usage:
#   ninja          — build everything
#   ninja clean    — remove build artifacts

arch = ${ARCH_DIR}
cc = ${CC}
ar = ${AR}
builddir = ${BUILDDIR}

cflags = ${CFLAGS} ${COMMON_FLAGS}
asflags = -Iinclude

# --- Rules ---

rule cc
  command = \$cc \$cflags -MMD -MF \$out.d -c \$in -o \$out
  depfile = \$out.d
  description = CC \$out

rule as
  command = \$cc \$asflags -c \$in -o \$out
  description = AS \$out

rule ar
  command = \$ar rcs \$out \$in
  description = AR \$out

rule link
  command = \$cc -nostdlib -nostartfiles -nodefaultlibs ${LDFLAGS} -T ${LDSCRIPT} \$in -o \$out ${STRIP:+&& ${STRIP}}
  description = LINK \$out

rule clean_cmd
  command = rm -rf \$builddir
  description = CLEAN

# --- Arch objects ---

build \$builddir/start.o: as arch/\$arch/start.S
build \$builddir/syscall.o: as arch/\$arch/syscall.S
build \$builddir/thread_asm.o: as arch/\$arch/thread.S
build \$builddir/clone_asm.o: as arch/\$arch/clone.S
build \$builddir/coroutine_asm.o: as arch/\$arch/coroutine.S

# --- Source objects ---

build \$builddir/mem.o: cc src/mem.c
build \$builddir/string.o: cc src/string.c
build \$builddir/print.o: cc src/print.c
build \$builddir/memory.o: cc src/memory.c
build \$builddir/heap.o: cc src/heap.c
build \$builddir/thread.o: cc src/thread.c
build \$builddir/io.o: cc src/io.c
build \$builddir/async.o: cc src/async.c
build \$builddir/socket.o: cc src/socket.c
build \$builddir/coroutine.o: cc src/coroutine.c
build \$builddir/format.o: cc src/format.c
build \$builddir/log.o: cc src/log.c
build \$builddir/time.o: cc src/time.c
build \$builddir/lightio.o: cc src/lightio.c
build \$builddir/library.o: cc src/library.c
build \$builddir/containers.o: cc src/containers.c
build \$builddir/signal.o: cc src/signal.c
build \$builddir/lifecycle.o: cc src/lifecycle.c

# --- Library ---

build \$builddir/liblightc.a: ar \$builddir/start.o \$builddir/syscall.o \$builddir/thread_asm.o \$builddir/clone_asm.o \$builddir/coroutine_asm.o \$builddir/mem.o \$builddir/string.o \$builddir/print.o \$builddir/memory.o \$builddir/heap.o \$builddir/thread.o \$builddir/io.o \$builddir/async.o \$builddir/socket.o \$builddir/coroutine.o \$builddir/format.o \$builddir/log.o \$builddir/time.o \$builddir/lightio.o \$builddir/library.o \$builddir/containers.o \$builddir/signal.o \$builddir/lifecycle.o

# --- Examples ---

build \$builddir/hello.o: cc examples/hello.c
build \$builddir/hello: link \$builddir/hello.o \$builddir/liblightc.a

build \$builddir/syscalls.o: cc examples/syscalls.c
build \$builddir/syscalls: link \$builddir/syscalls.o \$builddir/liblightc.a

build \$builddir/strings.o: cc examples/strings.c
build \$builddir/strings: link \$builddir/strings.o \$builddir/liblightc.a

build \$builddir/print.example.o: cc examples/print.c
build \$builddir/print.example: link \$builddir/print.example.o \$builddir/liblightc.a

build \$builddir/memory.example.o: cc examples/memory.c
build \$builddir/memory.example: link \$builddir/memory.example.o \$builddir/liblightc.a

build \$builddir/heap.example.o: cc examples/heap.c
build \$builddir/heap.example: link \$builddir/heap.example.o \$builddir/liblightc.a

rule cc_stats
  command = \$cc \$cflags -DLC_STATS=1 -MMD -MF \$out.d -c \$in -o \$out
  depfile = \$out.d
  description = CC \$out (LC_STATS=1)

# heapviz needs LC_STATS=1 for both its own code and the heap/memory objects
build \$builddir/heapviz.o: cc_stats examples/heapviz.c
build \$builddir/heap_stats.o: cc_stats src/heap.c
build \$builddir/memory_stats.o: cc_stats src/memory.c

# Build a stats-enabled library variant for heapviz
rule ar_stats
  command = cp \$builddir/liblightc.a \$out && \$ar d \$out heap.o memory.o 2>/dev/null; \$ar r \$out \$builddir/heap_stats.o \$builddir/memory_stats.o 2>/dev/null
  description = AR \$out

build \$builddir/liblightc_stats.a: ar_stats \$builddir/liblightc.a \$builddir/heap_stats.o \$builddir/memory_stats.o
build \$builddir/heapviz: link \$builddir/heapviz.o \$builddir/liblightc_stats.a

build \$builddir/thread.example.o: cc examples/thread.c
build \$builddir/thread.example: link \$builddir/thread.example.o \$builddir/liblightc.a

build \$builddir/bench_heap.o: cc examples/bench_heap.c
build \$builddir/bench_heap: link \$builddir/bench_heap.o \$builddir/liblightc.a

build \$builddir/bench_startup.o: cc examples/bench_startup.c
build \$builddir/bench_startup: link \$builddir/bench_startup.o \$builddir/liblightc.a

build \$builddir/io.example.o: cc examples/io.c
build \$builddir/io.example: link \$builddir/io.example.o \$builddir/liblightc.a

build \$builddir/async.example.o: cc examples/async.c
build \$builddir/async.example: link \$builddir/async.example.o \$builddir/liblightc.a

build \$builddir/socket.example.o: cc examples/socket.c
build \$builddir/socket.example: link \$builddir/socket.example.o \$builddir/liblightc.a

build \$builddir/httpd.o: cc examples/httpd.c
build \$builddir/httpd: link \$builddir/httpd.o \$builddir/liblightc.a

build \$builddir/coroutine.example.o: cc examples/coroutine.c
build \$builddir/coroutine.example: link \$builddir/coroutine.example.o \$builddir/liblightc.a

build \$builddir/format.example.o: cc examples/format.c
build \$builddir/format.example: link \$builddir/format.example.o \$builddir/liblightc.a

build \$builddir/log.example.o: cc examples/log.c
build \$builddir/log.example: link \$builddir/log.example.o \$builddir/liblightc.a

build \$builddir/time.example.o: cc examples/time.c
build \$builddir/time.example: link \$builddir/time.example.o \$builddir/liblightc.a

build \$builddir/lightio_echo.o: cc examples/lightio_echo.c
build \$builddir/lightio_echo: link \$builddir/lightio_echo.o \$builddir/liblightc.a

build \$builddir/lightio_http.o: cc examples/lightio_http.c
build \$builddir/lightio_http: link \$builddir/lightio_http.o \$builddir/liblightc.a

build \$builddir/lightio_test.o: cc examples/lightio_test.c
build \$builddir/lightio_test: link \$builddir/lightio_test.o \$builddir/liblightc.a

rule cc_shared
  command = gcc -shared -fPIC -nostdlib -o \$out \$in
  description = SO \$out

build \$builddir/test_plugin.so: cc_shared examples/test_plugin.c

build \$builddir/library.example.o: cc examples/library.c
build \$builddir/library.example: link \$builddir/library.example.o \$builddir/liblightc.a

build \$builddir/containers.example.o: cc examples/containers.c
build \$builddir/containers.example: link \$builddir/containers.example.o \$builddir/liblightc.a

# --- Tests ---

rule cc_test
  command = \$cc \$cflags -Itests -MMD -MF \$out.d -c \$in -o \$out
  depfile = \$out.d
  description = CC \$out

build \$builddir/test_string.o: cc_test tests/test_string.c
build \$builddir/test_string: link \$builddir/test_string.o \$builddir/liblightc.a

build \$builddir/test_format.o: cc_test tests/test_format.c
build \$builddir/test_format: link \$builddir/test_format.o \$builddir/liblightc.a

build \$builddir/test_containers.o: cc_test tests/test_containers.c
build \$builddir/test_containers: link \$builddir/test_containers.o \$builddir/liblightc.a

build \$builddir/test_memory.o: cc_test tests/test_memory.c
build \$builddir/test_memory: link \$builddir/test_memory.o \$builddir/liblightc.a

build \$builddir/test_heap.o: cc_test tests/test_heap.c
build \$builddir/test_heap: link \$builddir/test_heap.o \$builddir/liblightc.a

build \$builddir/test_thread.o: cc_test tests/test_thread.c
build \$builddir/test_thread: link \$builddir/test_thread.o \$builddir/liblightc.a

build \$builddir/test_coroutine.o: cc_test tests/test_coroutine.c
build \$builddir/test_coroutine: link \$builddir/test_coroutine.o \$builddir/liblightc.a

build \$builddir/test_io.o: cc_test tests/test_io.c
build \$builddir/test_io: link \$builddir/test_io.o \$builddir/liblightc.a

build \$builddir/test_time.o: cc_test tests/test_time.c
build \$builddir/test_time: link \$builddir/test_time.o \$builddir/liblightc.a

build \$builddir/test_print.o: cc_test tests/test_print.c
build \$builddir/test_print: link \$builddir/test_print.o \$builddir/liblightc.a

build tests: phony \$builddir/test_string \$builddir/test_format \$builddir/test_containers \$builddir/test_memory \$builddir/test_heap \$builddir/test_thread \$builddir/test_coroutine \$builddir/test_io \$builddir/test_time \$builddir/test_print

rule run_tests
  command = for t in \$in; do echo "--- \$\$t ---" && \$\$t || exit 1; done
  description = Running tests

build test: run_tests \$builddir/test_string \$builddir/test_format \$builddir/test_containers \$builddir/test_memory \$builddir/test_heap \$builddir/test_thread \$builddir/test_coroutine \$builddir/test_io \$builddir/test_time \$builddir/test_print

# --- Benchmarks ---

rule cc_bench
  command = \$cc \$cflags -Ibench -MMD -MF \$out.d -c \$in -o \$out
  depfile = \$out.d
  description = CC \$out

build \$builddir/bench_heap2.o: cc_bench bench/bench_heap.c
build \$builddir/bench_heap2: link \$builddir/bench_heap2.o \$builddir/liblightc.a

build \$builddir/bench_arena.o: cc_bench bench/bench_arena.c
build \$builddir/bench_arena: link \$builddir/bench_arena.o \$builddir/liblightc.a

build \$builddir/bench_string.o: cc_bench bench/bench_string.c
build \$builddir/bench_string: link \$builddir/bench_string.o \$builddir/liblightc.a

build \$builddir/bench_containers.o: cc_bench bench/bench_containers.c
build \$builddir/bench_containers: link \$builddir/bench_containers.o \$builddir/liblightc.a

build \$builddir/bench_thread.o: cc_bench bench/bench_thread.c
build \$builddir/bench_thread: link \$builddir/bench_thread.o \$builddir/liblightc.a

build \$builddir/bench_format.o: cc_bench bench/bench_format.c
build \$builddir/bench_format: link \$builddir/bench_format.o \$builddir/liblightc.a

build benchmarks: phony \$builddir/bench_heap2 \$builddir/bench_arena \$builddir/bench_string \$builddir/bench_containers \$builddir/bench_thread \$builddir/bench_format

rule run_benchmarks
  command = for t in \$in; do \$\$t || exit 1; done
  description = Running benchmarks

build bench: run_benchmarks \$builddir/bench_heap2 \$builddir/bench_arena \$builddir/bench_string \$builddir/bench_containers \$builddir/bench_thread \$builddir/bench_format

# --- Targets ---

build all: phony \$builddir/liblightc.a \$builddir/hello \$builddir/syscalls \$builddir/strings \$builddir/print.example \$builddir/memory.example \$builddir/heap.example \$builddir/thread.example \$builddir/bench_heap \$builddir/io.example \$builddir/async.example \$builddir/socket.example \$builddir/httpd \$builddir/coroutine.example \$builddir/format.example \$builddir/log.example \$builddir/time.example \$builddir/lightio_echo \$builddir/lightio_http \$builddir/lightio_test \$builddir/test_plugin.so \$builddir/library.example \$builddir/containers.example \$builddir/heapviz
default all

build clean: clean_cmd
EOF

echo "Configured: ${DESC} [${ARCH_DIR}]"
echo "Run 'ninja' to build."
